{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mycv-studio.steliospnev.dev/schemas/cv-import.schema.json",
  "title": "CV Import Payload",
  "description": "Schema for importing a CV from JSON text or file.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "fullName",
    "headline",
    "email",
    "phone",
    "location",
    "summary",
    "sections"
  ],
  "properties": {
    "fullName": {
      "type": "string",
      "minLength": 1
    },
    "headline": {
      "type": "string",
      "minLength": 1
    },
    "email": {
      "type": "string",
      "minLength": 1
    },
    "phone": {
      "type": "string",
      "minLength": 1
    },
    "location": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "sections": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["title", "kind", "items"],
        "properties": {
          "title": {
            "type": "string",
            "minLength": 1
          },
          "kind": {
            "type": "string",
            "enum": [
              "experience",
              "education",
              "projects",
              "skills",
              "languages"
            ]
          },
          "items": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["title", "subtitle", "period", "details"],
              "properties": {
                "title": {
                  "type": "string"
                },
                "subtitle": {
                  "type": "string"
                },
                "period": {
                  "type": "string"
                },
                "details": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    }
  }
}
