generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Cv {
  id          String      @id @default(cuid())
  fullName    String
  headline    String
  email       String
  phone       String
  location    String
  summary     String
  githubUrl   String      @default("")
  linkedinUrl String      @default("")
  sections    CvSection[]
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
}

model CvSection {
  id        String @id @default(cuid())
  cvId      String
  cv        Cv     @relation(fields: [cvId], references: [id], onDelete: Cascade)
  title     String
  kind      String
  sortOrder Int
  items     Json

  @@index([cvId, sortOrder])
}
